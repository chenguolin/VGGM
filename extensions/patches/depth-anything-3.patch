+def _distributed_flex_attention(q: Tensor, k: Tensor, v: Tensor, block_mask) -> Tensor:
+    # Ulysses-style SP: scatter heads and gather sequence
+    q = all_to_all(q, scatter_dim=1, gather_dim=2)  # (B, H//sp, N, D)
+    k = all_to_all(k, scatter_dim=1, gather_dim=2)  # (B, H//sp, N, D)
+    v = all_to_all(v, scatter_dim=1, gather_dim=2)  # (B, H//sp, N, D)
+
+    # Padding for flexattention (`128`: block size for flexattention)
+    padded_length = math.ceil(q.shape[2] / 128) * 128 - q.shape[2]
+    if padded_length > 0:
+        q = torch.cat([q, torch.zeros([q.shape[0], q.shape[1], padded_length, q.shape[3]], device=q.device, dtype=q.dtype)], dim=2)
+        k = torch.cat([k, torch.zeros([k.shape[0], k.shape[1], padded_length, k.shape[3]], device=k.device, dtype=k.dtype)], dim=2)
+        v = torch.cat([v, torch.zeros([v.shape[0], v.shape[1], padded_length, v.shape[3]], device=v.device, dtype=v.dtype)], dim=2)
+
+    x = flex_attention(
+        q,
+        k,
+        v,
+        block_mask=block_mask,
+    )
+    if padded_length > 0:
+        x = x[:, :, :-padded_length, ...]
+
+    # Scatter sequence back and gather heads
+    x = all_to_all(x, scatter_dim=2, gather_dim=1)  # (B, H, N//sp, D)
+    return x
+
